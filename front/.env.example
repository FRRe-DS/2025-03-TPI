# Keycloak OIDC Configuration
# Copy this file to .env.local and update with your values
NEXT_PUBLIC_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/ds-2025-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=grupo-11
NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
NEXT_PUBLIC_KEYCLOAK_SCOPE=envios:read

# Keycloak Client Secret (solo en servidor, NO usar NEXT_PUBLIC_)
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
